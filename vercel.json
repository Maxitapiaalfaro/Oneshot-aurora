{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "DEMO_MODE": "true"
  },
  "build": {
    "env": {
      "GEMINI_API_KEY": "@gemini_api_key",
      "DEMO_MODE": "true"
    }
  }
}
