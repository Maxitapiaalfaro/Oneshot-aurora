# ========================================
# AURORA PLATFORM - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ========================================

# ========================================
# MODO DEMO (Zero-Config)
# ========================================
# Para ejecutar Aurora en Modo Demo (sin Firebase):
# 1. Configure SOLO GEMINI_API_KEY
# 2. Los datos se almacenarán en memoria (no persisten entre reinicios)
# 3. Ideal para desarrollo y demostración en Vercel

# Google Gemini API (REQUERIDO - tanto para Demo como Producción)
GEMINI_API_KEY=your-gemini-api-key

# ========================================
# MODO PRODUCCIÓN (con Firebase)
# ========================================
# Para ejecutar Aurora en Modo Producción (con persistencia):
# 1. Configure las credenciales de Firebase a continuación
# 2. Configure GEMINI_API_KEY
# 3. Los datos se almacenarán en Firestore (persistencia permanente)

# Firebase Admin SDK Configuration (Server-Side Only)
# NUNCA incluir estas credenciales en el código del cliente
# Deje estas líneas comentadas o vacías para Modo Demo
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# ========================================
# CONFIGURACIÓN OPCIONAL
# ========================================

# Forzar Modo Demo explícitamente (opcional)
# Si está configurado en 'true', usará Modo Demo incluso si hay credenciales de Firebase
DEMO_MODE=false

# API Configuration (solo para modo desarrollo local con backend Express separado)
API_PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Security (JWT - solo para producción)
API_SECRET_KEY=your-secret-key-for-jwt
